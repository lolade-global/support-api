{
    "name": "lolade/support-api",
    "type": "project",
    "description": "A focused Laravel support-inbox API demonstrating queues, real-time broadcasting, third-party integration, and performance-minded data access.",
    "keywords": ["laravel", "api", "queues", "horizon", "broadcasting"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.61.1",
        "laravel/horizon": "^5.0",
        "laravel/sanctum": "^4.0",
        "pusher/pusher-php-server": "^7.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
