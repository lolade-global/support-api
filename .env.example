APP_NAME="Support API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Use sqlite for a zero-config local run; switch to mysql/pgsql for parity.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=support-api
# DB_USERNAME=root
# DB_PASSWORD=

# Queues run on Redis in production; Horizon supervises them.
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Real-time broadcasting via Pusher (or a Pusher-compatible server).
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# Twilio (only needed in staging/production; local uses the fake gateway).
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
